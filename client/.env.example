# Copy to .env or .env.local — Firebase Console → Project settings → Your apps (Web)
# Public site origin (no trailing slash) — used for social share image URL at build time. Required for correct previews on Facebook, LinkedIn, X.
VITE_SITE_URL=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
